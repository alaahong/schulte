.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  background-color: #f8fafc;
}

web-view {
  width: 100%;
  height: 100%;
}

.hint {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.45);
  z-index: 99;
  padding: 32rpx;
}

.hint-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  max-width: 560rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.18);
}

.hint-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 16rpx;
}

.hint-body {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.6;
  word-break: break-all;
}

.hint-action {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #0ea5e9;
  text-align: right;
}
