{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SchulteGrid",
  "version": "0.1.0",
  "identifier": "com.schulte.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Schulte Grid · Attention Training",
        "width": 900,
        "height": 700,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Schulte Grid attention training",
    "longDescription": "Cross-platform Schulte Grid attention training app for desktop, web and mobile.",
    "publisher": "Schulte App",
    "copyright": "© 2026",
    "iOS": {
      "minimumSystemVersion": "13.0"
    },
    "android": {
      "minSdkVersion": 24,
      "autoIncrementVersionCode": false
    }
  },
  "plugins": {}
}
